RewriteEngine On

# API Routes
RewriteRule ^api-login$ api-login.php [L]
RewriteRule ^api-register$ api-register.php [L]
RewriteRule ^api-me$ api-me.php [L]
RewriteRule ^api-leaderboard$ api-leaderboard.php [L]
RewriteRule ^api-submissions$ api-submissions.php [L]
RewriteRule ^api-team$ api-team.php [L]
RewriteRule ^api-payment-status$ api-payment-status.php [L]
RewriteRule ^api-verify-payment$ api-verify-payment.php [L]
RewriteRule ^api-webhook$ api-webhook.php [L]
RewriteRule ^api-admin-contestants$ api-admin-contestants.php [L]
RewriteRule ^api-admin-submissions$ api-admin-submissions.php [L]

# Enable CORS
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
